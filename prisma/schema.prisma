generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// เก็บว่าเว็บเราเลือกปี/เทอมไหน (แถวเดียว id=1)
// academicYearId อ้างถึง school_app.academic_years.id ซึ่งอยู่คนละ database
// จึงใส่ FK ไม่ได้ — อ่านรายการปีผ่าน raw query ใน src/lib/academicYear.ts
model ActiveSetting {
  id             Int      @id @default(1)
  academicYearId Int      @map("academic_year_id")
  semester       Int // 1 หรือ 2
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("active_setting")
}

// ตารางสำหรับครู — สร้างใหม่โดย db push
model Teacher {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  is_admin  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  problems Problem[]

  @@map("teachers")
}

// คลังโจทย์ของครู
model Problem {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  language    String   @default("python") // python (อนาคต: pandas, html, php, scratch)
  starterCode  String? @map("starter_code") @db.Text
  solutionCode String? @map("solution_code") @db.Text // เฉลยของครู — ใช้สร้าง output อัตโนมัติ + อ้างอิง (ไม่ส่งให้นักเรียน)
  datasetName    String? @map("dataset_name") // ชื่อไฟล์ข้อมูลแนบ เช่น data.csv (pandas)
  datasetContent String? @map("dataset_content") @db.MediumText // เนื้อหาไฟล์ — เขียนลง FS ของ Pyodide ก่อนรัน
  createdById  Int     @map("created_by_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   Teacher             @relation(fields: [createdById], references: [id])
  testCases   TestCase[]
  assignments AssignmentProblem[] // งานที่มีโจทย์ข้อนี้
  submissions Submission[]

  @@map("problems")
}

// เกณฑ์ตรวจของโจทย์ — ป้อน input ให้โปรแกรม แล้วเทียบ output
model TestCase {
  id             Int     @id @default(autoincrement())
  problemId      Int     @map("problem_id")
  input          String  @db.Text // stdin ที่ป้อนให้ (ว่างได้)
  expectedOutput String  @map("expected_output") @db.MediumText // text ที่คาดหวัง หรือ JSON ภาพวาด (turtle)
  isHidden       Boolean @default(false) @map("is_hidden") // เคสซ่อน — นักเรียนไม่เห็นรายละเอียด
  sortOrder      Int     @default(0) @map("sort_order")

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@map("test_cases")
}

// งานที่มอบหมาย เช่น "แบบฝึกหัดครั้งที่ 1" — มีได้หลายโจทย์ หลายเป้าหมาย ในปี/เทอมหนึ่ง
// academicYearId อ้างถึง school_app.academic_years.id (คนละ DB — ไม่มี FK)
model Assignment {
  id             Int       @id @default(autoincrement())
  title          String
  academicYearId Int       @map("academic_year_id")
  semester       Int
  dueAt          DateTime? @map("due_at")
  createdAt      DateTime  @default(now())

  problems    AssignmentProblem[]
  targets     AssignmentTarget[]
  submissions Submission[]

  @@map("assignments")
}

// โจทย์ในงาน — sortOrder คือลำดับข้อ (ข้อ 1, 2, 3...)
model AssignmentProblem {
  id           Int @id @default(autoincrement())
  assignmentId Int @map("assignment_id")
  problemId    Int @map("problem_id")
  sortOrder    Int @default(0) @map("sort_order")

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  problem    Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, problemId])
  @@map("assignment_problems")
}

// เป้าหมายของงาน — แถวละห้อง (classLevel+classRoom) หรือรายคน (studentCode พร้อมชั้น/ห้องไว้แสดงผล)
model AssignmentTarget {
  id           Int     @id @default(autoincrement())
  assignmentId Int     @map("assignment_id")
  classLevel   String  @map("class_level")
  classRoom    Int     @map("class_room")
  studentCode  String? @map("student_code") // null = ทั้งห้อง

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@map("assignment_targets")
}

// การส่งงานของนักเรียน — ตรวจในเบราว์เซอร์แล้วบันทึกผลรายข้อ
// studentCode เก็บตามรูปแบบใน school_app.students (ไม่เติม 0 นำหน้า)
model Submission {
  id           Int      @id @default(autoincrement())
  assignmentId Int      @map("assignment_id")
  problemId    Int      @map("problem_id")
  studentCode  String   @map("student_code")
  code         String   @db.Text
  passed       Int // จำนวนเคสที่ผ่าน (turtle: % ความเหมือน)
  total        Int // จำนวนเคสทั้งหมดตอนส่ง (turtle: 100)
  details      String?  @db.MediumText // JSON ผลรายเคส [true,false] หรือ JSON ภาพวาดของนักเรียน (turtle)
  createdAt    DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  problem    Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([assignmentId, problemId, studentCode])
  @@map("submissions")
}

// ตารางนักเรียน — ถ้ามีอยู่แล้วให้ใช้ prisma db pull แทน
model Student {
  id           Int      @id @default(autoincrement())
  student_code String   @unique
  citizen_id   String
  first_name   String
  last_name    String
  class_name   String?
  grade_level  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("students")
}
