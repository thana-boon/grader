# Database — MySQL connection string (เฉพาะข้อมูลของ codegrader: โจทย์/งาน/การส่ง/ครู)
DATABASE_URL="mysql://root:password@localhost:3306/codegrader"

# Student API — ข้อมูลนักเรียน/ปีการศึกษาดึงจาก API กลาง (เดิมอ่านตรงจาก school_app)
# ขอ key จากผู้ดูแล Student API:  node scripts/create-api-key.js "Grader" read:basic
#                                node scripts/create-api-key.js "Grader-Login" verify
STUDENT_API_BASE="http://192.168.200.9/students-api/v1"
STUDENT_API_KEY="sk_xxx_read_basic"   # scope read:basic
STUDENT_VERIFY_KEY="sk_xxx_verify"    # scope verify

# JWT secret — ควรเปลี่ยนเป็นค่าสุ่มยาวๆ ก่อน deploy production
JWT_SECRET="codegrader-super-secret-jwt-key-change-this"

# Environment
NODE_ENV="development"

# ที่อยู่ฐานของเว็บ — ตั้งเฉพาะบน server ที่อยู่หลัง reverse proxy เช่น "/grader"
# (เครื่อง dev ไม่ต้องตั้ง จะได้เข้า localhost:3000 ตรงๆ) ต้องตั้งก่อนสั่ง npm run build
# NEXT_PUBLIC_BASE_PATH="/grader"
